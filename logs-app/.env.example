# Path to the SQLite database file (created on first boot if missing).
DATABASE_PATH=data/logs.db

# Bootstrap admin account, seeded only when the users table is empty.
# ADMIN_PASSWORD_HASH must be a bcrypt hash (NOT a plaintext password).
# Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password',12))"
# IMPORTANT: escape every `$` in the hash as `\$`, otherwise the env loader
# expands `$2b`/`$12`/... and corrupts the hash.
ADMIN_USERNAME=admin
# Default hash below corresponds to the password: admin
ADMIN_PASSWORD_HASH=\$2b\$12\$xtPKUJCklCdI.BBw.A0dl.JbzbsTUgFaRc23CNeC7nX.o32BQQxUe
